<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Сеть — для yandex-слоя (скачивание/детект). Батарея/зарядка — сигналы для RunConstraints. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name="dev.humanonly.android.HumanonlyApp"
        android:allowBackup="false"
        android:label="humanonly"
        android:theme="@android:style/Theme.Material.Light">
        <!-- On-demand WorkManager: снимаем default-initializer androidx.startup, движок поднимает
             HumanonlyApp (Configuration.Provider) при первом getInstance. HumanonlyApp.onCreate ставит
             периодику. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Операторская панель sideload-сборки (положить токен / прогон вручную / статус). -->
        <activity
            android:name="dev.humanonly.android.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Экран ревью серой зоны (§F4-UI): человек ставит «ИИ»/«не ИИ». Не LAUNCHER — открывается
             из MainActivity. -->
        <activity
            android:name="dev.humanonly.android.ReviewActivity"
            android:exported="false" />

        <!-- Живой on-device smoke Media3-демуксера (§F6): демукс flac-mp4 → raw .flac и сверка упаковки
             STREAMINFO с платформенным MediaExtractor. Не LAUNCHER — открывается из MainActivity. -->
        <activity
            android:name="dev.humanonly.android.SmokeActivity"
            android:exported="false" />

        <!-- Живой end-to-end smoke §F6: скачать lossless из ЯМ → демукс → залить .flac на Яндекс.Диск
             (реальная цепочка DownloadStage+Archiver). Не LAUNCHER — открывается из MainActivity. -->
        <activity
            android:name="dev.humanonly.android.ArchiveSmokeActivity"
            android:exported="false" />

        <!-- Живой детект-smoke (§10): реальный каскад slopless+метаданные на одном треке → вердикт
             ИИ/human на экране. Не LAUNCHER — открывается из MainActivity. -->
        <activity
            android:name="dev.humanonly.android.DetectSmokeActivity"
            android:exported="false" />

        <!-- Чистка живой библиотеки лайков (§F4 + мёртвые лайки): dry-run скан → плейлисты → деструктив
             с бэкапом (хард-правило 5). Не LAUNCHER — открывается из MainActivity. -->
        <activity
            android:name="dev.humanonly.android.CleanupActivity"
            android:exported="false" />
    </application>

</manifest>
